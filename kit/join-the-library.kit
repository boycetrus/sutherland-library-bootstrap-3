<!DOCTYPE html>
<html>
  <head>
    <title>Library - Sutherland Shire Council</title>
    <!-- Bootstrap -->
    <!-- @import components/_head-content.htm -->
  </head>

  <body>
    <div class="container-fluid page-wrap">

      <!-- @import components/_alert.htm -->

      <!-- @import components/_header.htm -->

      <!-- @import components/_navbar.htm -->

      <!-- @import components/_breadcrumbs.htm -->

      <section id="main" class="main row" role="main">

          <div id="sidebar" class="col-md-3 col-lg-3 col-lg-offset-1 page-spotlight">
            <!-- @import components/_hero-img.htm -->
          </div><!-- /sidebar -->

          <div id="content" class="col-md-9 col-lg-6 content">

            <h1>Join the Library</h1>
            <p class="lead">Membership of Sutherland Shire Libraries is free and open to both
              residents and non-residents of the Sutherland Shire. Library members may borrow
              items from any branch library in the Sutherland Shire and access our digital collections.</p>

              <div id="existingMembers" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true" aria-labelledby="#modalLabel">
                <div class="modal-dialog" role="document">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h2 class="modal-title">Before You Proceed&hellip;</h2>
                    </div>
                    <div class="modal-body">
                      <p id="modalLabel" class="lead">Have you had a Library Card before?</p>
                      <p>Existing members should not join the Library again. If you have previously
                        had a library card you can try logging in to your account. If you have forgotten
                        your PIN/password you can try resetting it:</p>
                      <p><a href="https://encore.sutherlandshire.nsw.gov.au/iii/encore/myaccount">Login</a> or
                        <a href="https://webpac.sutherlandshire.nsw.gov.au/pinreset">Reset your PIN</a></p>
                      <p>If you have lost your library card or continue having trouble logging in to your
                        account please contact the Library for further information.</p>
                        <address>
                          <strong>Phone</strong> 9710 0351<br>
                          <strong>Email</strong> <a href="mailto:library@ssc.nsw.gov.au">library@ssc.nsw.gov.au</a><br>
                        </address>
                        <p>If you have not previously had a library card click Continue.</p>
                    </div>
                    <div class="modal-footer">
                      <a class="btn btn-default" data-dismiss="modal">Cancel</a>
                      <a class="btn btn-primary" href="application-form.html">Continue</a>
                    </div>
                  </div><!-- /.modal-content -->
                </div><!-- /.modal-dialog -->
              </div><!-- /.modal -->

            <p>If you join online at home you will need to visit one of our libraries and show
              proof of your identity and residential address to activate your membership, at
              which time you will receive your library card. <strong>Access to our digital collections is
              restricted until you complete this step</strong>.</p>

            <p>Children under 16 require a parent or guardian to provide identification as well
              proof of child, for example, a Medicare card, Centrelink/Health Care card or birth certificate.</p>

            <p><a href="#existingMembers" class="btn btn-success btn-lg" data-toggle="modal" data-target="#existingMembers">Join Now</a></p>

            <!-- @import components/_relatedlinks.htm -->

          </div><!-- /content -->


        </div><!-- /row -->

      </section><!--/main-->
    </div><!--/container-->

    <!-- @import components/_social.htm -->

    <!-- @import components/_footer.htm -->

  <script src="js/production/global-min.js"></script>
  </body>
</html>
